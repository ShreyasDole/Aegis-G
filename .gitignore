.installed.cfg
*.egg
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/
.ruff_cache/

# Virtual environments
venv/
.venv/
ENV/

# Node.js
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Next.js
frontend/.next/
frontend/out/
frontend/.vercel

# IDE
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store

# Docker
*.log

# Database
*.db
*.sqlite3

# Testing
coverage/
.nyc_output/

# Certificates (NEVER commit!)
*.pem
*.key
*.crt
deployment/nginx/ssl/

# Temporary files
tmp/
temp/
*.tmp

# OS files
Thumbs.db

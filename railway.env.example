# ============================================
# 🚀 Aegis-G — Railway Environment Variables
# ============================================
# Copy this into Railway → Project → Variables
# DO NOT commit your actual .env to git!
#
# Generate a secret key:
#   python -c "import secrets; print(secrets.token_hex(32))"
#
# Rotate your Gemini key first:
#   https://aistudio.google.com/app/apikey
# ============================================

# ── Core ──────────────────────────────────────────────────────────────────────
PROJECT_NAME=Aegis-G
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=INFO

# ── FastAPI Security ───────────────────────────────────────────────────────────
SECRET_KEY=REPLACE_WITH_GENERATED_KEY
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ── AI / Gemini ────────────────────────────────────────────────────────────────
GEMINI_API_KEY=REPLACE_WITH_YOUR_GEMINI_KEY
GEMINI_FLASH_MODEL=gemini-2.5-flash

# ── PostgreSQL (Railway managed — copy from Railway PostgreSQL service) ────────
# Railway auto-fills this if you add a PostgreSQL plugin to your project
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DBNAME
POSTGRES_USER=REPLACE
POSTGRES_PASSWORD=REPLACE
POSTGRES_DB=aegis

# ── Neo4j Aura (free cloud instance) ─────────────────────────────────────────
# Sign up at: https://console.neo4j.io
# Format: neo4j+s://xxxxxxxx.databases.neo4j.io
NEO4J_URI=neo4j+s://REPLACE.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=REPLACE_AURA_PASSWORD

# ── Redis (Upstash free tier) ─────────────────────────────────────────────────
# Sign up at: https://console.upstash.com
# Format: rediss://default:PASSWORD@HOST:PORT
REDIS_HOST=REPLACE.upstash.io
REDIS_PORT=6379
REDIS_PASSWORD=REPLACE_UPSTASH_PASSWORD

# ── CORS ──────────────────────────────────────────────────────────────────────
# Set this to your Vercel frontend URL after deploying the frontend
CORS_ORIGINS=https://your-app.vercel.app,http://localhost:3000

# ── Frontend URL (for OAuth redirects) ────────────────────────────────────────
FRONTEND_URL=https://your-app.vercel.app

# ── Microsoft OAuth (optional — only if you use Outlook login) ────────────────
OUTLOOK_CLIENT_ID=
OUTLOOK_TENANT_ID=
OUTLOOK_CLIENT_SECRET=
ENCRYPTION_KEY=REPLACE_WITH_GENERATED_KEY

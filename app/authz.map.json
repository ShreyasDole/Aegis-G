{
  "": "Aegis-G Authorization Rules",
  "_comment": "Define who can access what. Format: { '/path': { 'METHOD': ['role1', 'role2'] } }",
  
  "/api/system/health": {
    "ANY": ["*"]
  },
  
  "/api/threats": {
    "GET": ["admin", "analyst", "viewer"],
    "POST": ["admin", "analyst"],
    "PUT": ["admin", "analyst"],
    "DELETE": ["admin"]
  },
  
  "/api/reports": {
    "GET": ["admin", "analyst", "viewer"],
    "POST": ["admin", "analyst"],
    "PUT": ["admin", "analyst"],
    "DELETE": ["admin"]
  },
  
  "/api/scan/*": {
    "GET": ["admin", "analyst", "viewer"],
    "POST": ["admin", "analyst"]
  },
  
  "/api/analyze/*": {
    "GET": ["admin", "analyst"],
    "POST": ["admin", "analyst"]
  },
  
  "/api/network/*": {
    "GET": ["admin", "analyst", "viewer"],
    "POST": ["admin", "analyst"]
  },
  
  "/api/federated/*": {
    "GET": ["admin", "analyst"],
    "POST": ["admin"]
  },
  
  "/api/admin/*": {
    "ANY": ["admin"]
  },
  
  "/api/auth/me": {
    "ANY": ["admin", "analyst", "viewer"]
  },
  
  "/api/auth/refresh": {
    "ANY": ["admin", "analyst", "viewer"]
  },
  
  "/api/ai/policies": {
    "GET": ["admin", "analyst", "viewer"],
    "POST": ["admin", "analyst"],
    "DELETE": ["admin"]
  },
  
  "/api/ai/insights": {
    "GET": ["admin", "analyst", "viewer"]
  },
  
  "/api/ai/chat": {
    "POST": ["admin", "analyst", "viewer"]
  }
}


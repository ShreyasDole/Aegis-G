# ============================================
# 🛡️ AEGIS-G Environment Configuration
# ============================================
# Copy this file to .env and fill in your values
# cp env.example .env

# ============================================
# 🤖 AI / Gemini Configuration
# ============================================
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_FLASH_MODEL=gemini-1.5-flash
GEMINI_PRO_MODEL=gemini-1.5-pro

# ============================================
# 🗄️ PostgreSQL Database
# ============================================
DATABASE_URL=postgresql://aegis:aegis_password@db:5432/aegis
POSTGRES_USER=aegis
POSTGRES_PASSWORD=aegis_password
POSTGRES_DB=aegis

# ============================================
# 🕸️ Neo4j Graph Database
# ============================================
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# ============================================
# 🔐 Security / JWT
# ============================================
# IMPORTANT: Generate a strong secret key for production!
# Run: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-secure-random-string-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ============================================
# 🌐 CORS Configuration
# ============================================
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ============================================
# 📧 Outlook / Microsoft OAuth (Login)
# ============================================
# Azure AD app registration: https://portal.azure.com → App registrations
OUTLOOK_CLIENT_ID=
OUTLOOK_TENANT_ID=
OUTLOOK_CLIENT_SECRET=

# Used to encrypt stored OAuth refresh tokens (e.g. 32-byte hex: openssl rand -hex 32)
ENCRYPTION_KEY=
# Where to redirect after Microsoft sign-in (must match your frontend origin)
FRONTEND_URL=http://localhost:3000

# ============================================
# 🔌 Google MCP (Model Context Protocol)
# ============================================
# Connect to Google/Google Cloud remote MCP servers (threat intel, docs, BigQuery, Chronicle, etc.).
# Latest docs: https://docs.cloud.google.com/mcp/overview
# Manage servers: https://docs.cloud.google.com/mcp/manage-mcp-servers
# Supported products: https://docs.cloud.google.com/mcp/supported-products
# Enable: gcloud beta services mcp enable SERVICE --project=PROJECT_ID
# Auth: https://docs.cloud.google.com/mcp/authenticate-mcp (ADC or service account).
# Single server:
# MCP_SERVER_URL=https://bigquery.googleapis.com/mcp
# Multiple servers (comma-separated):
# MCP_SERVER_URLS=https://bigquery.googleapis.com/mcp,https://chronicle.REGION.rep.googleapis.com/mcp
# GCP project for quota/billing (x-goog-user-project header):
# MCP_GOOGLE_PROJECT_ID=your-gcp-project-id
#
# Developer Knowledge MCP – search Google official docs (Firebase, Cloud, Android, Maps):
# https://developers.google.com/knowledge/mcp
# Enable: gcloud beta services mcp enable developerknowledge.googleapis.com --project=PROJECT_ID
# Auth: API key (no IAM) or OAuth/ADC. Optional API key for this server only:
DEVELOPER_KNOWLEDGE_API_KEY=

# ============================================
# 📊 Monitoring (Optional)
# ============================================
LOG_LEVEL=INFO
ENABLE_METRICS=true

# ============================================
# 🚀 Application Settings
# ============================================
ENVIRONMENT=development
DEBUG=true
API_V1_PREFIX=/api


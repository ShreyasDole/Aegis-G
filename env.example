# ============================================
# 🛡️ AEGIS-G Environment Configuration
# ============================================
# Copy this file to .env and fill in your values
# cp env.example .env

# ============================================
# 🤖 AI / Gemini Configuration
# ============================================
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_FLASH_MODEL=gemini-1.5-flash
GEMINI_PRO_MODEL=gemini-1.5-pro

# ============================================
# 🗄️ PostgreSQL Database
# ============================================
DATABASE_URL=postgresql://aegis:aegis_password@db:5432/aegis
POSTGRES_USER=aegis
POSTGRES_PASSWORD=aegis_password
POSTGRES_DB=aegis

# ============================================
# 🕸️ Neo4j Graph Database
# ============================================
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# ============================================
# 🔐 Security / JWT
# ============================================
# IMPORTANT: Generate a strong secret key for production!
# Run: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-secure-random-string-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ============================================
# 🌐 CORS Configuration
# ============================================
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ============================================
# 🔑 Keycloak (Optional - for enterprise auth)
# ============================================
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=aegis
KEYCLOAK_CLIENT_ID=aegis-api
KEYCLOAK_CLIENT_SECRET=your-keycloak-secret

# ============================================
# 📊 Monitoring (Optional)
# ============================================
LOG_LEVEL=INFO
ENABLE_METRICS=true

# ============================================
# 🚀 Application Settings
# ============================================
ENVIRONMENT=development
DEBUG=true
API_V1_PREFIX=/api


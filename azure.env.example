# ============================================
# 🛡️ Aegis-G — Azure Environment Variables
# ============================================
# Paste these into:
#   Azure Portal → Container App → Settings → Environment variables
#   OR use: az containerapp update --set-env-vars KEY=VALUE ...
#
# ⚠️  NEVER commit real values to git.
#     Use Azure Key Vault references for secrets in production:
#     https://learn.microsoft.com/azure/container-apps/manage-secrets
#
# Generate a secret key:
#   python -c "import secrets; print(secrets.token_hex(32))"
#
# Rotate your Gemini key first:
#   https://aistudio.google.com/app/apikey
# ============================================

# ── Core ──────────────────────────────────────────────────────────────────────
PROJECT_NAME=Aegis-G
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=INFO

# ── FastAPI Security ───────────────────────────────────────────────────────────
SECRET_KEY=REPLACE_WITH_GENERATED_KEY
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ── AI / Gemini ────────────────────────────────────────────────────────────────
GEMINI_API_KEY=REPLACE_WITH_YOUR_GEMINI_KEY
GEMINI_FLASH_MODEL=gemini-2.5-flash

# ── PostgreSQL (Azure Database for PostgreSQL — Flexible Server) ──────────────
# Find under: Azure Portal → PostgreSQL → Connection strings → Python
# Format: postgresql://USER@SERVER:PASSWORD@SERVER.postgres.database.azure.com:5432/DB?sslmode=require
DATABASE_URL=postgresql://aegis%40SERVERNAME:PASSWORD@SERVERNAME.postgres.database.azure.com:5432/aegis_db?sslmode=require
POSTGRES_USER=aegis@SERVERNAME
POSTGRES_PASSWORD=REPLACE
POSTGRES_DB=aegis_db

# ── Neo4j Aura (free external cloud instance) ────────────────────────────────
# Sign up at: https://console.neo4j.io
# Format: neo4j+s://xxxxxxxx.databases.neo4j.io
NEO4J_URI=neo4j+s://REPLACE.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=REPLACE_AURA_PASSWORD

# ── Redis — Azure Cache for Redis (optional, your fallback works without it) ──
# Find under: Azure Portal → Azure Cache for Redis → Access Keys
# Format: rediss://:PASSWORD@HOSTNAME.redis.cache.windows.net:6380
REDIS_HOST=REPLACE.redis.cache.windows.net
REDIS_PORT=6380
REDIS_PASSWORD=REPLACE_REDIS_KEY

# ── CORS ──────────────────────────────────────────────────────────────────────
# Replace with your actual Vercel frontend URL
CORS_ORIGINS=https://your-app.vercel.app,http://localhost:3000

# ── Frontend URL (for OAuth redirects) ────────────────────────────────────────
FRONTEND_URL=https://your-app.vercel.app

# ── Azure AD OAuth (you already have this set up!) ────────────────────────────
# Your existing Azure AD app registration — same tenant, native integration
OUTLOOK_CLIENT_ID=REPLACE_YOUR_EXISTING_CLIENT_ID
OUTLOOK_TENANT_ID=REPLACE_YOUR_EXISTING_TENANT_ID
OUTLOOK_CLIENT_SECRET=REPLACE_YOUR_EXISTING_CLIENT_SECRET

# Used to encrypt stored OAuth refresh tokens
ENCRYPTION_KEY=REPLACE_WITH_GENERATED_KEY

# ── Gunicorn workers (2 is fine for Container Apps consumption plan) ──────────
GUNICORN_WORKERS=2
